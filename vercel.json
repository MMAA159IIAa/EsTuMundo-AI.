{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/automind/(.*)",
      "destination": "/apps/automind/dist/$1"
    },
    {
      "source": "/automind",
      "destination": "/apps/automind/dist/index.html"
    },
    {
      "source": "/beautly/(.*)",
      "destination": "/apps/beautly/dist/$1"
    },
    {
      "source": "/beautly",
      "destination": "/apps/beautly/dist/index.html"
    },
    {
      "source": "/estutanda/(.*)",
      "destination": "/apps/estutanda/dist/$1"
    },
    {
      "source": "/estutanda",
      "destination": "/apps/estutanda/dist/index.html"
    },
    {
      "source": "/media-lab/(.*)",
      "destination": "/apps/media-lab/dist/$1"
    },
    {
      "source": "/media-lab",
      "destination": "/apps/media-lab/dist/index.html"
    },
    {
      "source": "/taller-pro/(.*)",
      "destination": "/apps/taller-pro/dist/$1"
    },
    {
      "source": "/taller-pro",
      "destination": "/apps/taller-pro/dist/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/main-platform/dist/$1"
    }
  ]
}
