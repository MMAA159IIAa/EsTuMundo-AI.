{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/automind/(.*)",
      "destination": "/automind/index.html"
    },
    {
      "source": "/beautly/(.*)",
      "destination": "/beautly/index.html"
    },
    {
      "source": "/estutanda/(.*)",
      "destination": "/estutanda/index.html"
    },
    {
      "source": "/media-lab/(.*)",
      "destination": "/media-lab/index.html"
    },
    {
      "source": "/taller-pro/(.*)",
      "destination": "/taller-pro/index.html"
    }
  ]
}
