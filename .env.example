# ============================================
# Es Tu Mundo AI — Environment Variables
# ============================================

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# Google Cloud
GOOGLE_CLOUD_PROJECT_ID=estumundo-ai
GOOGLE_CLOUD_REGION=us-central1

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# WhatsApp Business API
WHATSAPP_API_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Firebase
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=estumundo-ai.firebaseapp.com
FIREBASE_PROJECT_ID=estumundo-ai
FIREBASE_STORAGE_BUCKET=estumundo-ai.appspot.com

# JWT Authentication
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY=7d

# App Config
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/api
